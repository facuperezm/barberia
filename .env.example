# See docs/deployment/go-live-runbook.md for production setup, and run
# `pnpm preflight` before launch to catch wrong-but-present values.

# Database — PostgreSQL connection string.
# LOCAL DEV: start the Docker stack (`pnpm db:up`) and use the line below. The
# `db.localtest.me` host resolves to 127.0.0.1 and tells the app to route the
# Neon serverless driver through the local proxy. This NEVER touches prod.
DATABASE_URL="postgres://postgres:postgres@db.localtest.me:5432/barbershop"
# PRODUCTION (Neon): use the POOLED connection string from the Neon dashboard.
# DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/db?sslmode=require"

# BetterAuth — passwordless magic-link auth (sessions/tokens signing secret).
# Generate one with: openssl rand -base64 32. Use a DISTINCT value in production.
BETTER_AUTH_SECRET="at-least-32-characters-long-random-secret"

# Resend (transactional email) — https://resend.com/api-keys
# Sending domain must be verified or magic-link login + booking emails fail.
RESEND_API_KEY="re_..."

# MercadoPago — https://www.mercadopago.com/developers
# In production these MUST be APP_USR- credentials. TEST- tokens process fake money.
MERCADOPAGO_ACCESS_TOKEN="APP_USR-..."
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY="APP_USR-..."
# Required: webhook signature secret (MP Dashboard -> Webhooks)
MERCADOPAGO_WEBHOOK_SECRET="..."

# Public base URL of the app (drives magic-link callbacks, MP redirects, and the
# webhook notification_url). In prod: https://your-domain.com, no trailing slash.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
